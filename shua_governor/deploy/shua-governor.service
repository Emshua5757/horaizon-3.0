[Unit]
Description=horAIzon 3.0 Central Governor Daemon
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=horaizon
Group=horaizon
WorkingDirectory=/opt/horaizon/shua_governor
ExecStart=/opt/horaizon/shua_governor/shua_governor --config /etc/horaizon/governor/config.toml
Restart=always
RestartSec=3s
LimitNOFILE=65536
Environment=RUST_LOG=info

[Install]
WantedBy=multi-user.target
