[Unit]
Description=horAIzon 3.0 Central Governor Daemon
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=shua
Group=shua
WorkingDirectory=/opt/horaizon/governor
ExecStart=/opt/horaizon/governor/shua_governor --config /etc/horaizon/governor/config.toml
Restart=always
RestartSec=3s
LimitNOFILE=65536
Environment=RUST_LOG=info

[Install]
WantedBy=multi-user.target
